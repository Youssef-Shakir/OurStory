<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>يوسف و كيان - ذكرياتنا</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&display=swap" rel="stylesheet">
</head>
<body>
    <header>
        <div class="header-content">
            <div class="logo">
                <h1>يوسف و كيان</h1>
            </div>
            <div class="header-buttons">
                <% if (isAdmin) { %>
                <a href="/curated" class="btn btn-curated">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                    </svg>
                    <span>الألبوم المميز</span>
                </a>
                <% } %>
                <a href="/logout" class="btn btn-logout">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9"/>
                    </svg>
                    <span>خروج</span>
                </a>
            </div>
        </div>
    </header>

    <main class="container">
        <% if (message) { %>
            <div class="alert <%= message.type %>"><%= message.text %></div>
        <% } %>

        <!-- Announcement Section -->
        <section class="announcement-section">
            <p class="announcement-text"><%= announcement %></p>
            <% if (isAdmin) { %>
                <button class="btn btn-edit-announcement" onclick="toggleAnnouncementEdit()">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                    </svg>
                </button>
                <form action="/update-announcement" method="POST" class="announcement-form" id="announcementForm">
                    <input type="text" name="announcement" value="<%= announcement %>" placeholder="أدخل النص هنا...">
                    <div class="announcement-buttons">
                        <button type="submit" class="btn btn-save">حفظ</button>
                        <button type="button" class="btn btn-cancel" onclick="toggleAnnouncementEdit()">إلغاء</button>
                    </div>
                </form>
            <% } %>
        </section>

        <!-- Upload Section -->
        <% if (canUpload) { %>
        <section class="upload-section">
            <div class="section-header">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/>
                </svg>
                <h2>إضافة ذكرى جديدة</h2>
            </div>
            <form action="/upload" method="POST" enctype="multipart/form-data" class="upload-form">
                <div class="form-row">
                    <div class="form-group file-input-wrapper">
                        <label for="media">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                                <circle cx="8.5" cy="8.5" r="1.5"></circle>
                                <polyline points="21 15 16 10 5 21"></polyline>
                            </svg>
                            <span>اختر صورة أو فيديو</span>
                        </label>
                        <input type="file" id="media" name="media" accept="image/*,video/*" required>
                        <span class="file-name">لم يتم اختيار ملف</span>
                    </div>
                    <div class="form-group">
                        <label for="date">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                <line x1="16" y1="2" x2="16" y2="6"></line>
                                <line x1="8" y1="2" x2="8" y2="6"></line>
                                <line x1="3" y1="10" x2="21" y2="10"></line>
                            </svg>
                            <span>التاريخ</span>
                        </label>
                        <input type="date" id="date" name="date">
                    </div>
                </div>
                <div class="form-group">
                    <label for="description">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="17" y1="10" x2="3" y2="10"></line>
                            <line x1="21" y1="6" x2="3" y2="6"></line>
                            <line x1="21" y1="14" x2="3" y2="14"></line>
                            <line x1="17" y1="18" x2="3" y2="18"></line>
                        </svg>
                        <span>الوصف</span>
                    </label>
                    <textarea id="description" name="description" rows="3" placeholder="ما قصة هذه الذكرى؟"></textarea>
                </div>
                <button type="submit" class="btn btn-primary btn-upload">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"/>
                    </svg>
                    <span>رفع الذكرى</span>
                </button>
            </form>

            <div class="divider">
                <span>أو</span>
            </div>

            <!-- YouTube Upload -->
            <form action="/upload-youtube" method="POST" class="upload-form youtube-form">
                <div class="section-header">
                    <svg viewBox="0 0 24 24" fill="currentColor" class="youtube-icon">
                        <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                    </svg>
                    <h3>إضافة فيديو يوتيوب</h3>
                </div>
                <div class="form-group">
                    <label for="youtubeUrl">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
                        </svg>
                        <span>رابط يوتيوب</span>
                    </label>
                    <input type="url" id="youtubeUrl" name="youtubeUrl" placeholder="https://www.youtube.com/watch?v=..." required>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="ytDate">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                <line x1="16" y1="2" x2="16" y2="6"></line>
                                <line x1="8" y1="2" x2="8" y2="6"></line>
                                <line x1="3" y1="10" x2="21" y2="10"></line>
                            </svg>
                            <span>التاريخ</span>
                        </label>
                        <input type="date" id="ytDate" name="date">
                    </div>
                    <div class="form-group">
                        <label for="ytDescription">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="17" y1="10" x2="3" y2="10"></line>
                                <line x1="21" y1="6" x2="3" y2="6"></line>
                                <line x1="21" y1="14" x2="3" y2="14"></line>
                                <line x1="17" y1="18" x2="3" y2="18"></line>
                            </svg>
                            <span>الوصف</span>
                        </label>
                        <input type="text" id="ytDescription" name="description" placeholder="وصف الفيديو">
                    </div>
                </div>
                <button type="submit" class="btn btn-youtube">
                    <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                    </svg>
                    <span>إضافة فيديو</span>
                </button>
            </form>
        </section>
        <% } %>

        <!-- Timeline/Roadmap -->
        <section class="roadmap">
            <div class="section-header centered">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
                <h2>رحلة يوسف و كيان</h2>
            </div>

            <% if (memories.length === 0) { %>
                <div class="empty-state">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                        <circle cx="8.5" cy="8.5" r="1.5"></circle>
                        <polyline points="21 15 16 10 5 21"></polyline>
                    </svg>
                    <p>لا توجد ذكريات بعد</p>
                    <span>ارفع أول صورة أو فيديو!</span>
                </div>
            <% } else { %>
                <div class="timeline">
                    <% memories.forEach((memory, index) => { %>
                        <div class="timeline-item" style="animation-delay: <%= index * 0.1 %>s">
                            <div class="timeline-marker">
                                <div class="marker-inner"></div>
                            </div>
                            <div class="timeline-content">
                                <div class="media-card">
                                    <% if (memory.type === 'youtube') { %>
                                        <div class="youtube-embed">
                                            <iframe
                                                src="https://www.youtube.com/embed/<%= memory.youtubeId %>"
                                                frameborder="0"
                                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                                allowfullscreen>
                                            </iframe>
                                        </div>
                                    <% } else if (memory.type === 'video') { %>
                                        <video controls>
                                            <source src="/uploads/<%= memory.filename %>" type="video/mp4">
                                            المتصفح لا يدعم الفيديو
                                        </video>
                                    <% } else { %>
                                        <img src="/uploads/<%= memory.filename %>" alt="ذكرى" loading="lazy">
                                    <% } %>
                                    <div class="media-info">
                                        <% if (memory.date) { %>
                                            <span class="media-date">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                                    <line x1="16" y1="2" x2="16" y2="6"></line>
                                                    <line x1="8" y1="2" x2="8" y2="6"></line>
                                                    <line x1="3" y1="10" x2="21" y2="10"></line>
                                                </svg>
                                                <%= memory.date %>
                                            </span>
                                        <% } %>
                                        <% if (memory.description) { %>
                                            <p class="media-description"><%= memory.description %></p>
                                        <% } %>
                                        <% if (canDelete) { %>
                                        <form action="/delete/<%= memory.id %>" method="POST" class="delete-form">
                                            <button type="submit" class="btn btn-delete" onclick="return confirm('هل أنت متأكد من حذف هذه الذكرى؟')">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <polyline points="3 6 5 6 21 6"></polyline>
                                                    <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                                                </svg>
                                                <span>حذف</span>
                                            </button>
                                        </form>
                                        <% } %>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </section>
    </main>

    <footer>
        <p>صُنع بكل حب بواسطة يوسف ❤️</p>
    </footer>

    <script>
        // File input display
        const mediaInput = document.getElementById('media');
        if (mediaInput) {
            mediaInput.addEventListener('change', function(e) {
                const fileName = e.target.files[0]?.name || 'لم يتم اختيار ملف';
                document.querySelector('.file-name').textContent = fileName;
            });
        }

        // Toggle announcement edit form
        function toggleAnnouncementEdit() {
            const form = document.getElementById('announcementForm');
            const text = document.querySelector('.announcement-text');
            const btn = document.querySelector('.btn-edit-announcement');

            if (form.style.display === 'none' || !form.style.display) {
                form.style.display = 'block';
                text.style.display = 'none';
                btn.style.display = 'none';
            } else {
                form.style.display = 'none';
                text.style.display = 'block';
                btn.style.display = 'flex';
            }
        }
    </script>
</body>
</html>
